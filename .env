ENV_NAME=php74
NAMESPACE=php74
PHP_VERSION=7.4
MYSQL_VERSION=8.0
PMA_VERSION=5.2.3
NODE_VERSION=24

APACHE_IMAGE=local/php-apache:${PHP_VERSION}
WORKER_IMAGE=local/php-worker:${PHP_VERSION}
WORKSPACE_IMAGE=local/workspace:${PHP_VERSION}
NODE_IMAGE=local/node:${NODE_VERSION}

APACHE_HOST_PORT=8080
PMA_HOST_PORT=8081
MYSQL_HOST_PORT=3306

PROJECTS_ROOT=../../../../var/www/php/7.4/
APACHE_CONFIG_PATH=./config/apache/sites
WORKER_CONFIG_PATH=./config/worker
MYSQL_DATA_PATH=./data/mysql

MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root

PMA_HOST=mysql
PMA_PORT=3306
